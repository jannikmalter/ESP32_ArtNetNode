# --- PlatformIO / ESP-IDF build output ---
.pio/

# Generated per-env sdkconfig. Regenerated from the tracked seed
# sdkconfig.defaults on first build and never hand-edited (use menuconfig),
# so keep only sdkconfig.defaults under version control.
sdkconfig
sdkconfig.*
!sdkconfig.defaults

# --- Build logs & status artifacts ---
*.log
*.exit

# --- Editor / tooling (local, per-user) ---
.vscode/
.claude/
